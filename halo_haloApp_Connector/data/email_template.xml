<?xml version="1.0" ?>
<odoo>
    <data noupdate="1">
        <record id="email_template_subscription_key" model="mail.template">
            <field name="name">Subscription Key - Send to Customer</field>
            <field name="model_id" ref="model_halo_cus_subscriptions"/>
            <field name="subject">Your Halo App Subscription Key</field>
            <field name="email_from">{{ user.email_formatted }}</field>
            <field name="email_to">{{ object.customer_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>Dear {{ object.customer_id.name }},</p>
                    <p>Thank you for your purchase. Here is your subscription key and installation instructions:</p>
                    <p>License Key: {{ object.key_value }}</p>
                    <p>Sales Order: {{ object.order_id.name }}</p>
                    <p>Installation Instructions:</p>
                    <ol>
                        <li>Logon to the app on your local machine</li>
                        <li>Click on business settings, then settings</li>
                        <li>Add the key in the license field</li>
                        <li>Add the sales order id to the sales order field</li>
                    </ol>
                    <p>If you have any questions, please don't hesitate to contact us.</p>
                </div>
            </field>
        </record>
    </data>
</odoo>