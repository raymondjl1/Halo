<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions -->
    <record id="action_halo_subscriptions" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">halo.cus.subscriptions</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create your first subscription.</p>
        </field>
    </record>

    <!-- Subscriptions Views -->
    <record id="view_halo_subscriptions_list" model="ir.ui.view">
        <field name="name">halo.cus.subscriptions.list</field>
        <field name="model">halo.cus.subscriptions</field>
        <field name="arch" type="xml">
            <list editable="top" create="1" delete="1" multi_edit="1" string="Subscriptions" open_form_view="True">
                <field name="customer_id" string="Customer" options="{'no_create': True}" widget="many2one"/>
                <field name="order_id" string="Sales Order" widget="many2one"/>
                <field name="user_group_id" string="User Group" widget="many2one"/>
                <field name="expiration_date" string="Expiration Date" widget="datetime"/>
            </list>
        </field>
    </record>


    <record id="view_halo_subscriptions_form" model="ir.ui.view">
        <field name="name">halo.cus.subscriptions.form</field>
        <field name="model">halo.cus.subscriptions</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="order_id"/>
                        <field name="user_group_id"/>
                        <field name="expiration_date"/>
                        <field name="key_value"/>
                        <button name="action_regenerate_key" string="Regenerate Key" type="object" class="btn-primary"/>
                    </group>
                   
                </sheet>
            </form>
        </field>
    </record>


    <!-- Menu Items -->

    <menuitem id="menu_halo_subscriptions"
              name="Subscriptions"
              parent="menu_halo_root"
              action="action_halo_subscriptions"
              sequence="20"/>
</odoo>
